# gitls configuration file
# Copy to ~/.gitlsrc to activate, or set GITLS_CONFIG=/path/to/file
#
# CLI flags always take precedence over these settings.

# Directory to scan when no DIRECTORY argument is given on the CLI.
# Passing an explicit path (including ".") always overrides this.
# default_dir=~/projects

# Maximum directory recursion depth (default: 5)
# max_depth=3

# Comma-separated list of directory names to skip.
# Glob patterns are supported: *, ?, [abc]
# skip_dirs=build,dist,tmp,node_modules,*.egg-info

# Default refresh interval (in seconds) for watch mode (-w). Default: 3
# watch_interval=5

# Only list repos that are not clean and in sync (like the --dirty flag).
# dirty_only=true

# Group repos by their parent folder into collapsible categories in watch
# mode (-w). On by default; set to false for one flat, alphabetical list.
# categories=true

# Disable ANSI colors (true or 1)
# no_color=false
